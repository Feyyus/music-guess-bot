{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "composite": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@feyyus/db": ["packages/db/src/index.ts"],
      "@feyyus/wallet": ["packages/wallet/src/index.ts"],
      "@feyyus/scheduler": ["packages/scheduler/src/index.ts"],
      "@feyyus/bot-kit": ["packages/bot-kit/src/index.ts"]
    }
  },
  "exclude": ["dist", "node_modules"]
}
